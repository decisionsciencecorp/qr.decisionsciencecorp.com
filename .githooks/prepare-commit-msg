#!/bin/sh
# Strip Cursor product co-author injection (credits cursoragent on GitHub).
# Repo-local hook — enable with: git config core.hooksPath .githooks
MSG_FILE="$1"
[ -f "$MSG_FILE" ] || exit 0
sed -i '/^Co-authored-by: Cursor /d' "$MSG_FILE" 2>/dev/null \
  || sed -i '' '/^Co-authored-by: Cursor /d' "$MSG_FILE" 2>/dev/null \
  || true
exit 0
